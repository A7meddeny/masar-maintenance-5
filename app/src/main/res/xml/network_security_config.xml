<?xml version="1.0" encoding="utf-8"?>
<!-- يسمح بالاتصال عبر HTTP وHTTPS. يُفضّل استخدام HTTPS للنطاق. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
